<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <include
            layout="@layout/clock_view"
            android:layout_width="@dimen/default_clock_size"
            android:layout_height="@dimen/default_clock_size"
            android:layout_gravity="center"/>

    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/check_digital"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Digital Mode" />

            <CheckBox
                android:id="@+id/check_seconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Seconds"
                android:checked="true" />

            <CheckBox
                android:id="@+id/check_milliseconds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Milliseconds" />

            <CheckBox
                android:id="@+id/check_partial_rotation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smooth Partial Rotation" />

            <CheckBox
                android:id="@+id/check_ambient"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ambient Mode" />

            <CheckBox
                android:id="@+id/check_low_bit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low Bit Ambient" />

            <CheckBox
                android:id="@+id/check_burn_in"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Burn-in Protection" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
